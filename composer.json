{
    "name": "praeviseo/symfony-bridge",
    "description": "Official lightweight Symfony bridge for connecting a client site to PraeviSEO.",
    "type": "symfony-bundle",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "doctrine/orm": "^2.18|^3.0",
        "symfony/console": "^6.4|^7.0|^8.0",
        "symfony/dependency-injection": "^6.4|^7.0|^8.0",
        "symfony/framework-bundle": "^6.4|^7.0|^8.0",
        "symfony/http-client": "^6.4|^7.0|^8.0",
        "symfony/http-foundation": "^6.4|^7.0|^8.0",
        "symfony/http-kernel": "^6.4|^7.0|^8.0",
        "symfony/routing": "^6.4|^7.0|^8.0",
        "twig/twig": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Praeviseo\\SymfonyBridge\\": "src/"
        }
    },
    "extra": {
        "symfony": {
            "bundle": "Praeviseo\\SymfonyBridge\\PraeviseoSymfonyBridge"
        }
    }
}
