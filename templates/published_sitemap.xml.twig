<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{% for page in pages %}
    {% if page.liveUrl %}
    <url>
        <loc>{{ page.liveUrl }}</loc>
        {% if page.lastPublishedAt %}
        <lastmod>{{ page.lastPublishedAt|date('c') }}</lastmod>
        {% endif %}
    </url>
    {% endif %}
{% endfor %}
</urlset>
